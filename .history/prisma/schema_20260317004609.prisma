generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?
  password      String?
  role          String    @default("member") // member | trainer | staff | admin
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  memberships   UserMembership[]
  bookings      Booking[]
  orders        Order[]
  wallet        Wallet?
  rewardPoints  RewardPoints?
  referral      Referral?
  notifications Notification[]
  complaints    Complaint[]
  handledChatSessions ChatSession[]  @relation("AssignedSupport")
  supportPresence     SupportPresence?
}

// ─── Membership ───────────────────────────────────────────────────────────────

model Membership {
  id          String  @id @default(cuid())
  name        String
  price       Float
  duration    Int     // days
  features    String  // JSON array stored as string
  maxClasses  Int     @default(-1) // -1 = unlimited
  walletBonus Float   @default(0)
  gift        String?
  isActive    Boolean @default(true)

  userMemberships UserMembership[]
  recommendedFor  ChatSession[]
}

model UserMembership {
  id           String   @id @default(cuid())
  userId       String
  membershipId String
  startDate    DateTime @default(now())
  endDate      DateTime
  status       String   @default("active") // active | expired | cancelled

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id])
}

// ─── Trainer ──────────────────────────────────────────────────────────────────

model Trainer {
  id             String  @id @default(cuid())
  name           String
  specialty      String
  bio            String?
  certifications String? // JSON array
  rating         Float   @default(5.0)
  sessionsCount  Int     @default(0)
  image          String?

  classes Class[]
}

// ─── Class ────────────────────────────────────────────────────────────────────

model Class {
  id          String  @id @default(cuid())
  name        String
  description String?
  trainerId   String
  type        String  // cardio | strength | yoga | boxing | swimming | dance
  duration    Int     // minutes
  intensity   String  // low | medium | high | extreme
  maxSpots    Int     @default(15)
  price       Float   @default(0)
  image       String?
  isActive    Boolean @default(true)

  trainer   Trainer    @relation(fields: [trainerId], references: [id])
  schedules Schedule[]
}

model Schedule {
  id             String   @id @default(cuid())
  classId        String
  date           DateTime
  time           String   // "06:00"
  availableSpots Int
  isActive       Boolean  @default(true)

  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id            String   @id @default(cuid())
  userId        String
  scheduleId    String
  status        String   @default("confirmed") // confirmed | cancelled | attended | noshow
  paidAmount    Float    @default(0)
  paymentMethod String   @default("wallet") // wallet | card | cash
  createdAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// ─── Product & Order ──────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float
  oldPrice    Float?
  category    String  // supplement | gear | clothing | accessory
  stock       Int     @default(0)
  images      String? // JSON array of URLs
  sizes       String? // JSON array
  colors      String? // JSON array
  isActive    Boolean @default(true)

  orderItems OrderItem[]
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  total         Float
  status        String   @default("pending") // pending | confirmed | delivered | cancelled
  address       String?
  paymentMethod String   @default("card")
  createdAt     DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  size      String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id      String @id @default(cuid())
  userId  String @unique
  balance Float  @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String   // credit | debit
  description String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ─── Rewards ──────────────────────────────────────────────────────────────────

model RewardPoints {
  id      String @id @default(cuid())
  userId  String @unique
  points  Int    @default(0)
  tier    String @default("bronze") // bronze | silver | gold | platinum

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  history RewardHistory[]
}

model RewardHistory {
  id        String   @id @default(cuid())
  rewardId  String
  points    Int
  reason    String
  createdAt DateTime @default(now())

  reward RewardPoints @relation(fields: [rewardId], references: [id], onDelete: Cascade)
}

// ─── Referral ─────────────────────────────────────────────────────────────────

model Referral {
  id           String @id @default(cuid())
  userId       String @unique
  code         String @unique
  totalEarned  Float  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info | success | warning | error
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Offer ────────────────────────────────────────────────────────────────────

model Offer {
  id          String   @id @default(cuid())
  title       String
  discount    Float
  description String?
  expiresAt   DateTime
  isActive    Boolean  @default(true)
}

// ─── Complaint ────────────────────────────────────────────────────────────────

model Complaint {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String   @default("open") // open | in-progress | resolved | closed
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id                    String   @id @default(cuid())
  visitorName           String?
  visitorPhone          String?
  status                String   @default("open") // open | live | resolved
  mode                  String   @default("bot") // bot | live
  context               String?  // JSON string for questionnaire state
  assignedToId          String?
  recommendedMembershipId String?
  lastMessageAt         DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignedTo            User?       @relation("AssignedSupport", fields: [assignedToId], references: [id])
  recommendedMembership Membership? @relation(fields: [recommendedMembershipId], references: [id])
  messages              ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  senderType String   // user | bot | admin | staff | system
  senderName String?
  content    String
  metadata   String?
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SupportPresence {
  id         String   @id @default(cuid())
  userId     String   @unique
  isOnline   Boolean  @default(false)
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SiteContent ──────────────────────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  section   String   @unique // hero | contact | trainers | blog | announcements | about
  content   String   // JSON string
  updatedAt DateTime @updatedAt
}

model ChatKnowledgeEntry {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("general")
  keywords  String
  answer    String
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


