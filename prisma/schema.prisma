generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?
  password      String?
  role          String    @default("member") // member | trainer | staff | admin
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  memberships   UserMembership[]
  bookings      Booking[]
  orders        Order[]
  paymentTransactions PaymentTransaction[]
  wallet        Wallet?
  rewardPoints  RewardPoints?
  referral      Referral?
  notifications Notification[]
  complaints    Complaint[]
  testimonials  Testimonial[]
  productReviews ProductReview[]
  handledChatSessions ChatSession[]  @relation("AssignedSupport")
  supportPresence     SupportPresence?
}

// ─── Membership ───────────────────────────────────────────────────────────────

model Membership {
  id          String  @id @default(cuid())
  name        String
  nameEn      String?
  kind        String  @default("subscription") // subscription | package
  price       Float
  priceBefore Float?
  priceAfter  Float?
  image       String?
  sortOrder   Int     @default(0)
  duration    Int     // days
  cycle       String? // monthly | quarterly | semi_annual | annual | custom
  sessionsCount Int?  // عدد الحصص للاشتراك
  features    String  // JSON array stored as string
  featuresEn  String?
  classSessions String? @db.LongText // JSON: class-specific sessions
  productRewards String? @db.LongText // JSON: product benefits for packages
  maxClasses  Int     @default(-1) // -1 = unlimited
  walletBonus Float   @default(0)
  gift        String?
  giftEn      String?
  isActive    Boolean @default(true)

  userMemberships UserMembership[]
  recommendedFor  ChatSession[]
  offers          Offer[]
  goals           MembershipGoal[]
}

model UserMembership {
  id           String   @id @default(cuid())
  userId       String
  membershipId String
  startDate    DateTime @default(now())
  endDate      DateTime
  status       String   @default("active") // active | expired | cancelled
  paymentAmount Float   @default(0)
  paymentMethod String? // cash | free | wallet | card | instapay | offer
  offerTitle    String?
  offerId       String?
  totalSessions Int?
  productRewardsUsed String? @db.LongText

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id])
  offer      Offer?     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  bookings   Booking[]
}

// ─── Trainer ──────────────────────────────────────────────────────────────────

model Trainer {
  id             String  @id @default(cuid())
  name           String
  nameEn         String?
  specialty      String
  specialtyEn    String?
  bio            String?
  bioEn          String? @db.Text
  certifications String? // JSON array
  certificationsEn String? // JSON array
  rating         Float   @default(5.0)
  sessionsCount  Int     @default(0)
  image          String?
  isActive       Boolean @default(true)
  showOnHome     Boolean @default(true)
  sortOrder      Int     @default(0)

  classes Class[]
}

// ─── Class ────────────────────────────────────────────────────────────────────

model Class {
  id          String  @id @default(cuid())
  name        String
  nameEn      String?
  description String?
  descriptionEn String? @db.Text
  trainerId   String
  category    String? // القسم الرئيسي
  categoryEn  String?
  type        String  // cardio | strength | yoga | boxing | swimming | dance
  typeEn      String?
  subType     String? // التصنيف الفرعي
  subTypeEn   String?
  duration    Int     // minutes
  intensity   String  // low | medium | high | extreme
  maxSpots    Int     @default(15)
  price       Float   @default(0)
  image       String?
  showTrainerName Boolean @default(true)
  isActive    Boolean @default(true)

  trainer   Trainer    @relation(fields: [trainerId], references: [id])
  schedules Schedule[]
}

model Schedule {
  id             String   @id @default(cuid())
  classId        String
  date           DateTime
  time           String   // "06:00"
  availableSpots Int
  isActive       Boolean  @default(true)

  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id            String   @id @default(cuid())
  userId        String
  scheduleId    String
  userMembershipId String?
  status        String   @default("confirmed") // confirmed | cancelled | attended | noshow
  paidAmount    Float    @default(0)
  paymentMethod String   @default("wallet") // wallet | card | cash
  createdAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  userMembership UserMembership? @relation(fields: [userMembershipId], references: [id], onDelete: SetNull)

  @@index([userMembershipId])
}

// ─── Product & Order ──────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  nameEn      String?
  description String? @db.Text
  descriptionEn String? @db.Text
  price       Float
  oldPrice    Float?
  category    String
  stock       Int     @default(0)
  sku         String? @unique
  unitLabel   String?
  trackInventory   Boolean @default(true)
  averageCost      Float   @default(0)
  lastPurchaseCost Float   @default(0)
  reorderLevel     Int     @default(0)
  images      String? // JSON array of URLs
  sizes       String? // JSON array
  colors      String? // JSON array
  isActive    Boolean @default(true)

  orderItems OrderItem[]
  reviews    ProductReview[]
  stockMovements      InventoryMovement[]    @relation("InventoryProduct")
  receiptItems        InventoryReceiptItem[] @relation("InventoryReceiptProduct")
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  businessUnit  String   @default("store") // store | club
  subtotal      Float    @default(0)
  discountTotal Float    @default(0)
  shippingFee   Float    @default(0)
  total         Float
  status        String   @default("pending") // pending | confirmed | delivered | cancelled
  deliveryOptionId String?
  deliveryLabel String?
  estimatedDeliveryDays Int?
  isClubPickup  Boolean  @default(false)
  recipientName String?
  recipientPhone String?
  address       String?
  notes         String?  @db.Text
  paymentMethod String   @default("card")
  createdAt     DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryOption DeliveryOption? @relation(fields: [deliveryOptionId], references: [id], onDelete: SetNull)
  items OrderItem[]
  paymentTransactions PaymentTransaction[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  size      String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model PaymentTransaction {
  id                String    @id @default(cuid())
  userId            String
  orderId           String?
  membershipId      String?
  offerId           String?
  purpose           String    // order | membership | wallet_topup
  businessUnit      String    @default("store") // store | club
  provider          String    // manual | paymob | paytabs | custom
  providerReference String?   @unique
  externalReference String?   @unique
  amount            Float
  currency          String    @default("EGP")
  status            String    @default("pending") // pending | requires_action | paid | failed | cancelled | expired
  paymentMethod     String    @default("card")
  checkoutUrl       String?
  iframeUrl         String?
  returnUrl         String?
  cancelUrl         String?
  providerPayload   String?   @db.LongText
  metadata          String?   @db.LongText
  expiresAt         DateTime?
  paidAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([orderId])
  @@index([provider, status])
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id      String @id @default(cuid())
  userId  String @unique
  balance Float  @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String   // credit | debit
  description String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ─── Rewards ──────────────────────────────────────────────────────────────────

model RewardPoints {
  id      String @id @default(cuid())
  userId  String @unique
  points  Int    @default(0)
  tier    String @default("bronze") // bronze | silver | gold | platinum

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  history RewardHistory[]
}

model RewardHistory {
  id        String   @id @default(cuid())
  rewardId  String
  points    Int
  reason    String
  createdAt DateTime @default(now())

  reward RewardPoints @relation(fields: [rewardId], references: [id], onDelete: Cascade)
}

// ─── Referral ─────────────────────────────────────────────────────────────────

model Referral {
  id            String @id @default(cuid())
  userId        String @unique
  code          String @unique
  totalEarned   Float  @default(0)
  referredCount Int    @default(0)

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ReferralUsage[]
}

model ReferralUsage {
  id             String   @id @default(cuid())
  referralId     String
  referredUserId String   @unique
  rewardGiven    Boolean  @default(false)
  rewardType     String?  // points | wallet
  rewardValue    Float?
  createdAt      DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
}

// ─── Discount Code ─────────────────────────────────────────────────────────────

model DiscountCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  descriptionEn String?
  type          String   @default("percentage") // percentage | fixed
  value         Float
  minAmount     Float?
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usages DiscountCodeUsage[]
}

model DiscountCodeUsage {
  id             String   @id @default(cuid())
  discountCodeId String
  userId         String
  membershipId   String?
  discountAmount Float
  createdAt      DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info | success | warning | error
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Offer ────────────────────────────────────────────────────────────────────

model Offer {
  id                 String      @id @default(cuid())
  title              String
  titleEn            String?
  type               String      @default("percentage") // percentage | fixed | special
  discount           Float
  description        String?     @db.Text
  descriptionEn      String?     @db.Text
  appliesTo          String?
  appliesToEn        String?
  expiresAt          DateTime
  isActive           Boolean     @default(true)
  membershipId       String?
  specialPrice       Float?
  maxSubscribers     Int?
  currentSubscribers Int         @default(0)
  image              String?
  showOnHome         Boolean     @default(false)
  showMaxSubscribers Boolean     @default(true)

  membership Membership? @relation(fields: [membershipId], references: [id])
  userMemberships UserMembership[]
}

model ProductCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  labelEn   String?
  sizeType  String   @default("none") // none | clothing | shoes
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClubGoal {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  slug        String   @unique
  description String?  @db.Text
  descriptionEn String? @db.Text
  image       String?
  kind        String   @default("standard") // standard | games_root | games_adults | games_children
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      ClubGoal?         @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ClubGoal[]        @relation("GoalHierarchy")
  classRules  GoalClassRule[]
  membershipGoals MembershipGoal[]
}

model MembershipGoal {
  id           String   @id @default(cuid())
  membershipId String
  goalId       String
  createdAt    DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  goal       ClubGoal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([membershipId, goalId])
  @@index([goalId])
}

model HealthQuestion {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  slug        String   @unique
  prompt      String
  promptEn    String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restrictions HealthQuestionRestriction[]
}

model HealthQuestionRestriction {
  id         String   @id @default(cuid())
  questionId String
  classType  String
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  question HealthQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, classType])
}

model GoalClassRule {
  id         String   @id @default(cuid())
  goalId     String
  classType  String
  rule       String   @default("recommended") // recommended | blocked | optional
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  goal ClubGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, classType, rule])
}


model DeliveryOption {
  id                 String   @id @default(cuid())
  name               String
  nameEn             String?
  type               String   @default("courier") // courier | pickup
  description        String?  @db.Text
  descriptionEn      String?  @db.Text
  fee                Float    @default(0)
  estimatedDaysMin   Int?
  estimatedDaysMax   Int?
  isActive           Boolean  @default(true)
  showCashOnDelivery Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders Order[]
}

model InventoryReceipt {
  id              String   @id @default(cuid())
  referenceNumber String?  @unique
  supplierName    String?
  notes           String?  @db.Text
  receivedAt      DateTime @default(now())
  status          String   @default("posted") // draft | posted | cancelled
  totalCost       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items InventoryReceiptItem[]
}

model InventoryReceiptItem {
  id         String   @id @default(cuid())
  receiptId  String
  productId  String
  quantity   Int
  unitCost   Float
  totalCost  Float
  createdAt  DateTime @default(now())

  receipt InventoryReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product          @relation("InventoryReceiptProduct", fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id                String   @id @default(cuid())
  productId         String
  type              String   // purchase | sale | adjustment | package_consumption | return
  quantityChange    Int
  quantityBefore    Int
  quantityAfter     Int
  unitCost          Float?
  averageCostBefore Float?
  averageCostAfter  Float?
  referenceType     String?
  referenceId       String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  product Product @relation("InventoryProduct", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

// ─── Complaint ────────────────────────────────────────────────────────────────

model Complaint {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String   @default("open") // open | in-progress | resolved | closed
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id                    String   @id @default(cuid())
  visitorName           String?
  visitorPhone          String?
  status                String   @default("open") // open | live | resolved
  mode                  String   @default("bot") // bot | live
  context               String?  // JSON string for questionnaire state
  assignedToId          String?
  recommendedMembershipId String?
  lastMessageAt         DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignedTo            User?       @relation("AssignedSupport", fields: [assignedToId], references: [id])
  recommendedMembership Membership? @relation(fields: [recommendedMembershipId], references: [id])
  messages              ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  senderType String   // user | bot | admin | staff | system
  senderName String?
  content    String   @db.Text
  metadata   String?
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SupportPresence {
  id         String   @id @default(cuid())
  userId     String   @unique
  isOnline   Boolean  @default(false)
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SiteContent ──────────────────────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  section   String   @unique // hero | contact | trainers | blog | announcements | about
  content   String   @db.LongText // JSON string
  updatedAt DateTime @updatedAt
}

model ChatKnowledgeEntry {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("general")
  keywords  String
  answer    String
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  userId      String
  displayName String?
  displayNameEn String?
  content     String
  contentEn   String?  @db.Text
  rating      Int      @default(5)
  status      String   @default("pending") // pending | approved | rejected
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
